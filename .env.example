# Contact form (Vercel → Project Settings → Environment Variables)
# Create a key at https://resend.com — free tier is enough for a portfolio.
RESEND_API_KEY=re_xxxxxxxx

# Where messages land (not exposed on the website)
CONTACT_TO_EMAIL=joepatbob@me.com

# Must be a verified sender in Resend (use onboarding@resend.dev until your domain is verified)
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# Optional: extra origin for preview deployments
# CONTACT_ALLOWED_ORIGIN=https://your-preview.vercel.app
